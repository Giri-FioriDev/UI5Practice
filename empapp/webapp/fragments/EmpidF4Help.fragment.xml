<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
<Dialog title='Select an Employee ID' id='empIdHelpDialog' class='empIdHelpDialog'>
    <content>
        <SearchField width='100%' placeholder='Search by Employee ID' liveChange='onEmpIdSearch'/>
    </content>
</Dialog>
    <Table items="{oEmpModel>/EmployeeItems}">
        <columns>
            <Column width="4%">
                <Text text="{i18n>col.empid}" />
            </Column>
            <Column width="8%">
                <Text text="{i18n>col.name}" />
            </Column>
            <Column width="6%">
                <Text text="{i18n>col.desig}" />
            </Column>
            <Column width="3%">
                <Text text="{i18n>col.skill}"></Text>
            </Column>
        </columns>
        <items>
            <ColumnListItem vAlign="Middle">
                <Text text="{oEmpModel>Empid}" />
                <Text text="{oEmpModel>Name}" wrapping="true" maxLines="2" />
                <Text text="{oEmpModel>Desig}" wrapping="true" maxLines="2" />
                <Text text="{oEmpModel>Skill}"></Text>
            </ColumnListItem>
        </items>
    </Table>
</core:FragmentDefinition>
