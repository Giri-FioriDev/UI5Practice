<mvc:View controllerName="com.demo.empapp.controller.EmployeView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form"
    xmlns="sap.m">
    <Page id="page1" title="Employee Management App" titleAlignment="Center">
    <content>
    <f:SimpleForm editable="true" class="sapUiResponsiveContentPadding" layout="ResponsiveGridLayout" labelSpanL="2" labelSpanM="2" emptySpanL="8" emptySpanM="8">
       <f:content>
       <Label text="{i18n>col.empid}"/>
       <Input id="empIdInput" value="{oEmpModel>/EmpId}" showValueHelp="true" valueHelpRequest="onIdValueHelp"/>
        <Label text="Select Employee Status" />
        <Select id="empStatusSelect" items="{oLocalModel>/oStatusData}" change="onEmpStatusChange">
             <core:Item key="{oLocalModel>status}" text="{oLocalModel>status}"/>
        </Select>
       </f:content>
    </f:SimpleForm>
   	<IconTabBar
		expanded="true"
		class="sapUiResponsiveContentPadding">
		<items>
			<IconTabFilter text=" Employee Table (sap.m)" key="mTable">
                <core:Fragment fragmentName="com.demo.empapp.fragments.EmpMTable" type="XML"/>
			</IconTabFilter>
			<IconTabFilter text="Employee Table (sap.ui.table)" key="attachments">
				<core:Fragment fragmentName="com.demo.empapp.fragments.EmpUITable" type="XML"/>
			</IconTabFilter>
            <IconTabFilter text="Employee List (sap.m)" key="listView">
				<core:Fragment fragmentName="com.demo.empapp.fragments.EmpList" type="XML"/>
			</IconTabFilter>
              <IconTabFilter text="Employee Custom List (sap.m)" key="customListView">
				<core:Fragment fragmentName="com.demo.empapp.fragments.EmpCustomList" type="XML"/>
			</IconTabFilter>
		</items>
	</IconTabBar>
     
    </content>
    <footer>
        <Toolbar >
        <ToolbarSpacer />
        <Button text="Show Details" type="Emphasized" press="onNavigateToDetails"></Button>
        </Toolbar>
    </footer>
    </Page>
</mvc:View>